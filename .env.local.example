# Morgan Wallen Official Fan Site — Environment Variables

# Public site URL (required for canonical URLs, emails, push links)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Session signing secret (generate: openssl rand -base64 32)
SESSION_SECRET=change-me-to-a-random-32-char-secret

# Resend email (https://resend.com)
# onboarding@resend.dev only delivers to your Resend account email until domain is verified
RESEND_API_KEY=
EMAIL_FROM=Morgan Wallen Fan <onboarding@resend.dev>

# Comma-separated admin emails for signup/application alerts
ADMIN_ALERT_EMAIL=admin@morganwallen.fan

# Supabase (production) — leave empty for Excel fallback in local dev
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Web Push VAPID keys (run: npm run generate-vapid)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@morganwallen.fan

# Ticketmaster Discovery API — auto-fetch Morgan Wallen shows for admin approval
# Free key: https://developer.ticketmaster.com/
TICKETMASTER_API_KEY=
# Optional; defaults to Morgan Wallen's Ticketmaster attraction ID
TICKETMASTER_ATTRACTION_ID=K8vZ9171o1V

# Secret for scheduled show fetch (Authorization: Bearer <CRON_SECRET>)
# Call GET /api/cron/fetch-shows on a schedule (e.g. daily via Vercel Cron)
CRON_SECRET=
